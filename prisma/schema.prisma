generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SECRETARIA
  FINANCEIRO
  PROFESSOR
  VISUALIZADOR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
}

enum StatusPresenca {
  PRESENTE
  AUSENTE
  JUSTIFICADO
  ATESTADO
}

enum DestinatarioComunicado {
  TODOS
  TURMA
  RESPONSAVEIS
  PROFESSORES
  STAFF
}

model User {
  id          String    @id @default(uuid())
  supabaseId  String    @unique
  nome        String
  email       String    @unique
  role        UserRole  @default(SECRETARIA)
  ativo          Boolean   @default(true)
  avatarUrl      String?
  assinaturaUrl  String?
  lastLoginAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  auditLogs    AuditLog[]
  tarefas      Tarefa[]
  chamadas     Chamada[]
  comunicados  Comunicado[]
  notificacoes Notificacao[]

  @@index([email])
  @@index([supabaseId])
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  userEmail String?
  action    AuditAction
  entity    String
  entityId  String
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model Turma {
  id         String   @id @default(cuid())
  nome       String
  curso      String
  turno      String
  horario    String
  ativo      Boolean  @default(true)
  capacidade Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  alunos      Aluno[]  @relation("TurmaPrincipal")
  alunos2     Aluno[]  @relation("TurmaSecundaria")
  alunos3     Aluno[]  @relation("TurmaTerciaria")
  chamadas    Chamada[]
  materiais   Material[]
  comunicados Comunicado[]
}

model Aluno {
  id                 String    @id @default(cuid())
  nome               String
  cpf                String    @unique
  email              String?
  telefone           String?
  foto               String?
  dataNascimento     DateTime?
  dataMatricula      DateTime
  situacaoMatricula  String    @default("ATIVO")
  observacoes        String?
  senha              String?
  diaVencimento      Int?
  valorMensalidade   Float?
  anotacaoFinanceiro String?
  cpfResponsavel     String?
  emListaMaterial    Boolean   @default(false)
  materialPago       Boolean   @default(false)
  materialEnviado    Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  turmaId  String
  turma    Turma   @relation("TurmaPrincipal", fields: [turmaId], references: [id])
  turmaId2 String?
  turma2   Turma?  @relation("TurmaSecundaria", fields: [turmaId2], references: [id])
  turmaId3 String?
  turma3   Turma?  @relation("TurmaTerciaria", fields: [turmaId3], references: [id])

  pagamentos  Parcela[]
  presencas   Presenca[]
  responsavel Responsavel?

  @@index([nome])
  @@index([deletedAt])
  @@index([turmaId])
  @@index([turmaId2])
  @@index([turmaId3])
}

model Parcela {
  id            String    @id @default(cuid())
  numero        Int
  valor         Float
  vencimento    DateTime
  pago          Boolean   @default(false)
  dataPagamento DateTime?
  nfEmitida     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  deletedAt     DateTime?

  alunoId String
  aluno   Aluno  @relation(fields: [alunoId], references: [id])

  @@index([alunoId])
  @@index([vencimento])
  @@index([deletedAt])
  @@map("Mensalidade")
}

model Chamada {
  id        String   @id @default(uuid())
  turmaId   String
  data      DateTime
  autorId   String
  fechada   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  turma     Turma      @relation(fields: [turmaId], references: [id])
  autor     User       @relation(fields: [autorId], references: [id])
  presencas Presenca[]

  @@unique([turmaId, data])
  @@index([turmaId])
  @@index([data])
}

model Presenca {
  id         String         @id @default(uuid())
  chamadaId  String
  alunoId    String
  status     StatusPresenca @default(AUSENTE)
  observacao String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  chamada Chamada @relation(fields: [chamadaId], references: [id])
  aluno   Aluno   @relation(fields: [alunoId], references: [id])

  @@unique([chamadaId, alunoId])
  @@index([alunoId])
}

model Material {
  id        String    @id @default(cuid())
  titulo    String
  arquivo   String
  ordem     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  turmaId String
  turma   Turma  @relation(fields: [turmaId], references: [id])
}

model Responsavel {
  id        String    @id @default(cuid())
  nome      String
  cpf       String?
  telefone  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  alunoId String @unique
  aluno   Aluno  @relation(fields: [alunoId], references: [id])
}

model ConfiguracaoSheet {
  id        String   @id @default(cuid())
  turmaId   String
  sheetId   String
  nomeAba   String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Despesa {
  id            String    @id @default(cuid())
  nome          String
  valor         Float
  diaVencimento Int
  pago          Boolean   @default(false)
  dataPagamento DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([diaVencimento])
  @@index([pago])
}

model Tarefa {
  id          String    @id @default(uuid())
  titulo      String
  prazo       DateTime?
  concluida   Boolean   @default(false)
  concluidaEm DateTime?
  autorId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  autor User @relation(fields: [autorId], references: [id])

  @@index([autorId, concluida])
}

model Comunicado {
  id           String                 @id @default(uuid())
  titulo       String
  corpo        String
  destinatario DestinatarioComunicado @default(TODOS)
  turmaId      String?
  autorId      String
  publicadoEm  DateTime?
  rascunho     Boolean                @default(true)
  fixado       Boolean                @default(false)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  deletedAt    DateTime?

  turma Turma? @relation(fields: [turmaId], references: [id])
  autor User   @relation(fields: [autorId], references: [id])

  @@index([publicadoEm])
  @@index([destinatario])
  @@index([deletedAt])
}

model Notificacao {
  id        String    @id @default(uuid())
  userId    String
  titulo    String
  mensagem  String?
  link      String?
  lida      Boolean   @default(false)
  lidaEm    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, lida])
  @@index([createdAt])
}

model Configuracao {
  id        String   @id @default(uuid())
  chave     String   @unique
  valor     Json
  updatedAt DateTime @updatedAt

  @@index([chave])
}
